Package: ggtimeline
Type: Package
Title: Flexible Timeline Visualisations for ggplot2
Version: 0.1.0
Date: 2026-07-09
Authors@R: c(
    person("Brooks", "Benard",
           email = "brooksbenard10@gmail.com",
           role  = c("aut", "cre"),
           comment = c(ORCID = "0000-0001-7154-744X"))
